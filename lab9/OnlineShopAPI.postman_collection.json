              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Category\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/categories/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "categories", "1", ""]
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/categories/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "categories", "1", ""]
            }
          }
        }
      ]
    },
